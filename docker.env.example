# Copy this file to docker.env and fill in your values
# docker.env is gitignored — never commit it

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=helpdesk

# App
DATABASE_URL=postgresql://postgres:your_db_password_here@db:5432/helpdesk
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail (use an App Password, not your main password)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=HelpDesk Support
SUPPORT_EMAIL=support@yourdomain.com

# Sentry (optional)
SENTRY_DSN=https://your_sentry_dsn_here

# Server
PORT=3001
NODE_ENV=production

# Admin seed account
ADMIN_EMAIL=admin@helpdesk.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Admin
